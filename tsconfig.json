{
  "compilerOptions": {
    "target": "es2017",
    "ignoreDeprecations": "6.0", // FOR NOW. This is for esModuleInterop
    "esModuleInterop": false,
    "module": "es6",
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "declaration": true,
    "declarationDir": "./dist/dts",
    "strictNullChecks": true
  },
  "include": ["src/index.ts"],
  "exclude": ["node_modules"]
}
